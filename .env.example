# ALLOWED_HOSTS=api.yourdomain.com
# SECURE_SSL_REDIRECT=True

# Supabase backend integration
SUPABASE_URL=https://bkkftnavcqufaxrskdwo.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=MyChama
SUPABASE_STORAGE_PUBLIC=False
SUPABASE_STORAGE_SIGNED_URL_TTL=3600
SUPABASE_REQUEST_TIMEOUT=5
# Direct DB host is IPv6-only on Supabase. For IPv4-only servers, prefer the
# Session pooler string from Supabase Dashboard -> Connect -> Connection pooling.
# Example format:
# DATABASE_POOL_URL=postgresql://postgres.<project-ref>:your-db-password@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_POOL_URL=
DATABASE_URL=postgresql://postgres:your-db-password@db.bkkftnavcqufaxrskdwo.supabase.co:5432/postgres?sslmode=require
DB_SSLMODE=verify-full
DB_SSLROOTCERT=/absolute/path/to/prod-ca-2021.crt
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password

# Frontend Expo public envs live in Mychama-app/.env
# EXPO_PUBLIC_SUPABASE_URL=https://bkkftnavcqufaxrskdwo.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

