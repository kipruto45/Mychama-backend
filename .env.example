# Supabase (Database + Storage)
# - To use Supabase Postgres, set DATABASE_URL (or DATABASE_POOL_URL for the Supabase pooler).
# - To use Supabase Storage for media (recommended; required in production when PRIVATE_MEDIA_STORAGE_REQUIRED=True),
#   set SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, and SUPABASE_STORAGE_BUCKET.
#
# Supabase local (via `supabase start`):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_URL=https://bkkftnavcqufaxrskdwo.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_REQUEST_TIMEOUT=5
SUPABASE_STORAGE_BUCKET=MyChama
SUPABASE_STORAGE_PUBLIC=False
SUPABASE_STORAGE_SIGNED_URL_TTL=3600
EXPO_PUSH_ACCESS_TOKEN=
FIREBASE_ANALYTICS_ENABLED=False
BACKUP_DIR=./backups
TEMP_FILE_ROOT=/tmp
BACKUP_INTEGRITY_CHECK_ENABLED=True
PRIVATE_MEDIA_STORAGE_REQUIRED=True
KYC_SIGNED_URL_TTL_SECONDS=900
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_SCAN_TIMEOUT_SECONDS=10
PRIVACY_POLICY_VERSION=2026.04
RETENTION_FINANCIAL_DAYS=2555
RETENTION_KYC_DAYS=1825
RETENTION_SECURITY_LOG_DAYS=365
RETENTION_CONSENT_DAYS=730
DATA_BREACH_NOTIFY_WINDOW_HOURS=72
FRAUD_STEP_UP_SCORE_THRESHOLD=61
FRAUD_FREEZE_SCORE_THRESHOLD=81
FRAUD_REVIEW_SLA_HOURS=24
FRAUD_LARGE_TRANSACTION_HOLD_KES=100000
AML_SINGLE_TRANSACTION_THRESHOLD_KES=1000000
AML_STRUCTURING_THRESHOLD_KES=1000000
AML_STRUCTURING_WINDOW_HOURS=24
PAGERDUTY_ROUTING_KEY=
ALERT_FAILED_LOGIN_SPIKE_THRESHOLD=25
ALERT_FRAUD_SPIKE_THRESHOLD=10
ALERT_KYC_FAILURE_THRESHOLD=20
ALERT_API_P95_SECONDS=1.5

# PostHog analytics
POSTHOG_ENABLED=False
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=

# OpenAI tuning
OPENAI_PROJECT=
