APP_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_READ_DOT_ENV_FILE=True
DEBUG=True
SECRET_KEY=replace-with-a-secure-secret
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=digital_chama
POSTGRES_USER=chama_app
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql://chama_app:change-me-db-password@postgres:5432/digital_chama
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=300

CORS_ALLOW_ALL_ORIGINS=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
API_ENABLE_SESSION_AUTH=False
API_ENABLE_BASIC_AUTH=False
ENABLE_FRONTEND_ROUTES=False
CACHE_URL=redis://redis:6379/1

PASSWORD_RESET_TOKEN_MINUTES=30
LOGIN_LOCKOUT_FAILURE_LIMIT=5
LOGIN_LOCKOUT_COOLDOWN_SECONDS=900
LOGIN_NEW_DEVICE_ALERT_ENABLED=True
LOGIN_NEW_DEVICE_ALERT_CHANNELS=email
SECURITY_ANOMALY_WINDOW_MINUTES=60
SECURITY_FAILED_LOGINS_IP_THRESHOLD=5
SECURITY_STK_FAILURE_THRESHOLD=5
SECURITY_RAPID_PAYOUT_THRESHOLD=5
SECURITY_ROLE_CHANGE_THRESHOLD=4
REPORT_CACHE_TTL_SECONDS=300
AUTOMATION_QUIET_HOURS_START=21
AUTOMATION_QUIET_HOURS_END=7
AUTOMATION_NOTIFICATION_DAILY_LIMIT=20
NOTIFICATION_BEHAVIORAL_THRESHOLD=20
AUTOMATION_JOB_LOCK_SECONDS=600
LOAN_AUTO_PENALTY_CAP_PERCENT=10
MEETING_REMINDER_WINDOW_MINUTES=30
MEETING_REMINDER_LEAD_HOURS=24
MEETING_DEFAULT_DURATION_MINUTES=120
MEETING_MINUTES_MAX_FILE_SIZE_MB=5
MEETING_MINUTES_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.txt
ISSUE_ATTACHMENT_MAX_FILE_SIZE_MB=10
ISSUE_ATTACHMENT_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf
DRF_THROTTLE_LOGIN=5/minute
DRF_THROTTLE_LOGIN_IDENTIFIER=6/minute
DRF_THROTTLE_REGISTER=5/minute
DRF_THROTTLE_REGISTER_IDENTIFIER=5/hour
DRF_THROTTLE_OTP_REQUEST=6/hour
DRF_THROTTLE_OTP_IDENTIFIER=6/hour
DRF_THROTTLE_PASSWORD_RESET=3/minute
DRF_THROTTLE_PASSWORD_RESET_IDENTIFIER=5/hour
DRF_THROTTLE_ISSUE_CREATE=30/hour
DRF_THROTTLE_ISSUE_MODERATION=60/hour
DRF_THROTTLE_AI_CHAT=30/hour
DRF_THROTTLE_AI_ACTION=20/hour
MEMBERSHIP_REQUEST_EXPIRY_DAYS=7
MEMBERSHIP_REVIEW_REMINDER_HOURS=24
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
X_FRAME_OPTIONS=DENY
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
CONTENT_SECURITY_POLICY=
PERMISSIONS_POLICY=camera=(), geolocation=(), microphone=()
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Email settings
EMAIL_PROVIDER=django
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# SMS settings
SMS_PROVIDER=africastalking
AFRICAS_TALKING_USERNAME=your-username
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_SENDER_ID=CHAMA
OTP_CALLBACK_TOKEN_HEADER=X-OTP-Callback-Token
OTP_SMS_CALLBACK_TOKEN=replace-with-dev-sms-callback-token
OTP_EMAIL_CALLBACK_TOKEN=replace-with-dev-email-callback-token
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
OTP_RESEND_WINDOW_SECONDS=600
OTP_MAX_RESENDS_PER_WINDOW=3
OTP_DELIVERY_RETRY_LIMIT=2
OTP_LOCKOUT_SECONDS=600
OTP_ALLOW_MOCK_DELIVERY=False

# Dev-only OTP console printing (for testing without real SMS/email)
PRINT_OTP_IN_CONSOLE=False

# Alternative SMS providers
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# SendGrid (alternative email provider)
SENDGRID_FROM_EMAIL=your-email@gmail.com
SENDGRID_API_KEY=your-sendgrid-key

# OpenAI / AI settings
OPENAI_API_KEY=
AI_CHAT_MODEL=gpt-5-mini
AI_MODERATION_MODEL=omni-moderation-latest
AI_EMBEDDING_MODEL=text-embedding-3-small

# M-Pesa settings
SITE_URL=http://localhost:8000
MPESA_USE_STUB=True
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_IP_ALLOWLIST=196.201.214.200,196.201.214.206,196.201.213.114
MPESA_CALLBACK_SIGNATURE_HEADER=X-MPESA-SIGNATURE
MPESA_CALLBACK_SECRET=replace-with-strong-callback-secret
PAYMENTS_CALLBACK_REQUIRE_IP_ALLOWLIST=True
PAYMENTS_CALLBACK_REQUIRE_SIGNATURE=True

# Daraja canonical config (production: set MPESA_USE_STUB=False)
DARAJA_CONSUMER_KEY=your-consumer-key
DARAJA_CONSUMER_SECRET=your-consumer-secret
DARAJA_SHORTCODE=your-shortcode
DARAJA_PASSKEY=your-passkey
DARAJA_CALLBACK_BASE_URL=https://your-public-domain
DARAJA_B2C_INITIATOR_NAME=your-initiator-name
DARAJA_B2C_INITIATOR_PASSWORD=your-initiator-password
DARAJA_CERT_PATH=/app/certs/SandboxCertificate.cer
DARAJA_SECURITY_CREDENTIAL=
DARAJA_B2C_SHORTCODE=your-b2c-shortcode
DARAJA_ENV=sandbox

# Production security defaults
# APP_ENV=production
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=False
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# PAYMENTS_CALLBACK_REQUIRE_IP_ALLOWLIST=True
# PAYMENTS_CALLBACK_REQUIRE_SIGNATURE=True

# Firebase Cloud Messaging (Push Notifications)
# Get service account from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=/app/config/firebase-service-account.json
# CORS_ALLOW_ALL_ORIGINS=False
# ALLOWED_HOSTS=api.yourdomain.com
# SECURE_SSL_REDIRECT=True
