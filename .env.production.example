SITE_URL=https://my-chama-app.onrender.com
ENABLE_DEV_ENDPOINTS=False
PRINT_OTP_IN_CONSOLE=False
ENABLE_DEV_OTP_ENDPOINT=False
OTP_ALLOW_MOCK_DELIVERY=False

POSTGRES_DB=digital_chama
POSTGRES_USER=digital_chama
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://digital_chama:replace-with-a-strong-password@postgres:5432/digital_chama
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
