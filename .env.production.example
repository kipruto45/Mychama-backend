APP_ENV=production
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_READ_DOT_ENV_FILE=False
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=api.my-chama-app.onrender.com,my-chama-app.onrender.com,www.my-chama-app.onrender.com
