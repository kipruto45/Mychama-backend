EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=replace-with-your-email-provider-secret
DEFAULT_FROM_EMAIL=no-reply@your-domain.com
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@your-domain.com

