          minLength: 1
          maxLength: 16
        phone_verified:
          type: boolean
        otp_verified:
          type: boolean
        phone_verified_at:
          type: string
          format: date-time
          nullable: true
        email_verified:
          type: boolean
        email_verified_at:
          type: string
          format: date-time
          nullable: true
        email:
          type: string
          format: email
          nullable: true
