      - phone
    UssdCallbackRequest:
      type: object
      properties:
        sessionId:
          type: string
          minLength: 1
        serviceCode:
          type: string
        phoneNumber:
          type: string
          minLength: 1
        text:
          type: string
        chama_id:
          type: string
          format: uuid
      required:
      - phoneNumber
      - sessionId
    UssdCallbackResponse:
      type: object
      properties:
        response:
          type: string
      required:
