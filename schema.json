    PatchedApprovalRequestRequest:
      type: object
      description: Serializer for approval requests
      properties:
        chama:
          type: string
          format: uuid
        approval_type:
          $ref: '#/components/schemas/ApprovalTypeEnum'
        reference_type:
          type: string
          minLength: 1
          description: Model name this approval is for (e.g., 'Loan', 'Expense')
          maxLength: 100
        reference_id:
          type: string
          format: uuid
          description: ID of the object being approved
        reference_display:
          type: string
          minLength: 1
          description: 'Human-readable reference (e.g., ''Loan #123'')'
          maxLength: 255
        title:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,13}(?:\.\d{0,2})?$
          nullable: true
        currency:
          type: string
          minLength: 1
          maxLength: 3
        requested_by:
          type: string
          format: uuid
          nullable: true
        required_level:
          $ref: '#/components/schemas/ApprovalLevelEnum'
        first_level_approver_role:
          type: string
          nullable: true
          description: Role required for first level approval (e.g., 'treasurer')
          maxLength: 50
        second_level_approver_role:
          type: string
          nullable: true
          description: Role required for second level approval (e.g., 'chairperson')
          maxLength: 50
        first_level_threshold:
          type: string
          format: decimal
          pattern: ^-?\d{0,13}(?:\.\d{0,2})?$
          nullable: true
          description: Amount threshold for first level approval
