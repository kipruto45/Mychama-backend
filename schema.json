    VoteEnum:
      enum:
      - 'yes'
      - 'no'
      - abstain
      type: string
      description: |-
        * `yes` - Yes
        * `no` - No
        * `abstain` - Abstain
    VoteTypeEnum:
      enum:
      - ordinary
      - special
      - unanimous
      type: string
      description: |-
        * `ordinary` - Ordinary Vote
        * `special` - Special Vote (2/3 majority)
        * `unanimous` - Unanimous Vote
    WithdrawalRequest:
