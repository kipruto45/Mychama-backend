components:
  schemas:
    AcknowledgmentStatusEnum:
      enum:
      - pending
      - acknowledged
      - expired
      type: string
      description: |-
        * `pending` - Pending
        * `acknowledged` - Acknowledged
        * `expired` - Expired
    ActionEnum:
      enum:
      - retry_verification
      - mark_reconciled
      - mark_failed
      type: string
      description: |-
        * `retry_verification` - Retry Verification
        * `mark_reconciled` - Mark Reconciled
        * `mark_failed` - Mark Failed
    ActionTypeEnum:
      enum:
      - CREATE
      - WITHDRAW
      - MODIFY
      type: string
      description: |-
        * `CREATE` - Create Investment
        * `WITHDRAW` - Withdraw Funds
        * `MODIFY` - Modify Terms
    AdminDeliveryLog:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        notification:
          type: string
          format: uuid
          readOnly: true
        notification_subject:
          type: string
          readOnly: true
        notification_type:
          type: string
          readOnly: true
        notification_priority:
          type: string
          readOnly: true
        recipient_id:
          type: string
          format: uuid
          readOnly: true
        recipient_name:
          type: string
          readOnly: true
        chama_id:
          type: string
          format: uuid
          readOnly: true
        channel:
          allOf:
          - $ref: '#/components/schemas/NotificationChannelEnum'
          readOnly: true
        to_address:
          type: string
          readOnly: true
        provider:
          type: string
          readOnly: true
        status:
          allOf:
          - $ref: '#/components/schemas/NotificationDeliveryStatusEnum'
          readOnly: true
        provider_message_id:
          type: string
          readOnly: true
        attempts:
          type: integer
          readOnly: true
        error_message:
          type: string
          readOnly: true
        last_attempt_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        delivered_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - attempts
      - chama_id
      - channel
      - created_at
      - delivered_at
      - error_message
      - id
      - last_attempt_at
      - notification
      - notification_priority
      - notification_subject
      - notification_type
      - provider
      - provider_message_id
      - recipient_id
      - recipient_name
      - status
      - to_address
      - updated_at
    AdminTransactionsQuery:
      type: object
      properties:
        chama_id:
          type: string
          format: uuid
        status:
          $ref: '#/components/schemas/PaymentIntentStatusEnum'
        intent_type:
          $ref: '#/components/schemas/IntentTypeEnum'
        purpose:
          $ref: '#/components/schemas/LegacyPaymentPurposeEnum'
        phone:
          type: string
        receipt:
          type: string
        search:
          type: string
        member_id:
          type: string
          format: uuid
        loan_id:
          type: string
          format: uuid
        from_date:
          type: string
          format: date
        to_date:
          type: string
          format: date
      required:
      - chama_id
    AllReportsResponse:
      type: object
      properties:
        results:
          type: array
          items: {}
        count:
          type: integer
        page:
          type: integer
        total_pages:
          type: integer
      required:
      - count
      - page
      - results
      - total_pages
    AmountTypeEnum:
      enum:
      - FLAT
      - PERCENT
      type: string
      description: |-
        * `FLAT` - Flat Amount
        * `PERCENT` - Percentage
    ApprovalLevelEnum:
      enum:
      - first
      - second
      - final
      type: string
      description: |-
        * `first` - First Approval
        * `second` - Second Approval
        * `final` - Final Approval
    ApprovalRequest:
      type: object
      description: Serializer for approval requests
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        chama:
          type: string
          format: uuid
        approval_type:
          $ref: '#/components/schemas/ApprovalTypeEnum'
        approval_type_display:
          type: string
          readOnly: true
        reference_type:
          type: string
          description: Model name this approval is for (e.g., 'Loan', 'Expense')
          maxLength: 100
        reference_id:
          type: string
          format: uuid
          description: ID of the object being approved
        reference_display:
          type: string
          description: 'Human-readable reference (e.g., ''Loan #123'')'
          maxLength: 255
        title:
          type: string
          maxLength: 255
        description:
          type: string
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,13}(?:\.\d{0,2})?$
          nullable: true
        currency:
          type: string
          maxLength: 3
        requested_by:
          type: string
          format: uuid
          nullable: true
        requested_by_name:
          type: string
          readOnly: true
        status:
          allOf:
          - $ref: '#/components/schemas/GovernanceApprovalStatusEnum'
          readOnly: true
        status_display:
          type: string
          readOnly: true
        required_level:
