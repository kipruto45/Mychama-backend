          maxLength: 160
        beneficiary_phone:
          type: string
          maxLength: 16
        beneficiary_details:
          type: string
        purpose:
          type: string
          default: OTHER
        reference_type:
          type: string
          default: OTHER
          maxLength: 40
        reference_id:
          type: string
          format: uuid
        idempotency_key:
          type: string
          maxLength: 100
      required:
      - amount
      - chama_id
      - phone
    WithdrawalRequestRequest:
      type: object
      properties:
        chama_id:
          type: string
          format: uuid
